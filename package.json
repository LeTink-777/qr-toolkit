{
  "name": "qr-toolkit",
  "version": "1.0.0",
  "main": "src/app/index.tsx",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "eslint 'src/**/*.{ts,tsx}' '__tests__/**/*.{ts,tsx}'",
    "lint:fix": "eslint 'src/**/*.{ts,tsx}' --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx,json}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx,json}'",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:e2e": "maestro test e2e/",
    "prepare": "husky"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "1.23.1",
    "expo": "~51.0.0",
    "expo-camera": "~15.0.0",
    "expo-haptics": "~13.0.0",
    "expo-media-library": "~16.0.0",
    "expo-screen-capture": "~6.0.0",
    "expo-secure-store": "~13.0.0",
    "expo-sharing": "~12.0.0",
    "expo-sqlite": "~14.0.0",
    "expo-status-bar": "~1.12.0",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "react-native-gesture-handler": "~2.16.0",
    "react-native-reanimated": "~3.10.0",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "3.31.1",
    "react-native-svg": "15.2.0",
    "react-native-qrcode-svg": "^6.3.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.10.1",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@gorhom/bottom-sheet": "^4.6.4",
    "zustand": "^4.5.4",
    "immer": "^10.1.1",
    "zod": "^3.23.8",
    "i18next": "^23.12.2",
    "react-i18next": "^15.0.1",
    "expo-clipboard": "~6.0.0",
    "expo-linking": "~6.3.0",
    "expo-contacts": "~13.0.0",
    "expo-file-system": "~17.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~18.2.79",
    "@types/jest": "^29.5.12",
    "@testing-library/react-native": "^12.6.1",
    "@testing-library/jest-native": "^5.4.3",
    "typescript": "~5.3.3",
    "eslint": "^8.57.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-import": "^2.29.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "prettier": "^3.3.3",
    "husky": "^9.1.4",
    "lint-staged": "^15.2.8",
    "jest": "^29.7.0",
    "jest-expo": "~51.0.0",
    "react-test-renderer": "18.2.0",
    "babel-plugin-module-resolver": "^5.0.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterSetup": [
      "./__tests__/setup.ts"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/e2e/"
    ],
    "collectCoverageFrom": [
      "src/features/*/lib/**/*.ts",
      "src/infrastructure/**/*.ts",
      "src/shared/lib/**/*.ts",
      "src/entities/*/model/**/*.ts"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|react-native-qrcode-svg|@gorhom/.*|zustand|immer)"
    ]
  },
  "private": true
}
